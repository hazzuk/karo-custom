---

name: whoami
services:

  whoami:
    image: {{ compose.whoami.image }}:{{ compose.whoami.version }}
    container_name: whoami
    restart: {{ karo_compose_restart_policy }}
    networks:
      - frontend
    labels:
      - traefik.enable=true
      - traefik.http.routers.whoami.rule=Host(`{{ compose.whoami.domain }}`)
      # - traefik.http.routers.whoami.tls=true
      # - traefik.http.routers.whoami.tls.certresolver=cloudflare
      # - traefik.http.routers.dashboard.entrypoints=websecure
      - traefik.http.services.whoami.loadbalancer.server.port=80
{% if compose.whoami.forward_auth_enabled %}
      # forward auth
      - traefik.http.routers.whoami.middlewares=tinyauth
      - tinyauth.apps.whoami.config.domain={{ compose.whoami.domain }}
      - tinyauth.apps.whoami.oauth.groups={{ karo_compose_oidc_admin_group }}
      - tinyauth.apps.whoami.path.allow=^\/api
{% endif %}

networks:
  frontend:
    external: true
