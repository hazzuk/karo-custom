global
  log stdout format raw local0
  stats timeout 30s

defaults
  # logging
  log global
  option dontlognull
  option tcplog

  # connections
  option tcpka
  option tcp-smart-accept
  option tcp-smart-connect

  # timeouts
  timeout connect 10s
  timeout check   10s
  timeout client  30s
  timeout server  30s
  timeout tunnel  1h

frontend http
  bind *:80
  mode http

  # https redirect
  http-request redirect scheme https code 301 if !{ ssl_fc }

frontend https
  bind *:443
  mode tcp

  {{ compose.haproxy.config_raw }}
